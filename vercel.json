{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm ci --legacy-peer-deps && npm run build:web",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/backend.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/backend.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/backend.py"
    },
    {
      "source": "/index",
      "destination": "/api/backend.py"
    },
    {
      "source": "/ask",
      "destination": "/api/backend.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
